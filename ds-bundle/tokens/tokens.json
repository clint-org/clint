{
  "$meta": {
    "name": "Clint Design Tokens",
    "description": "Competitive intelligence for pharma. Tokens-only export (no components). The brand teal scale is whitelabel-overridable in the live app; teal is the canonical Clint brand. Data colors never change with whitelabel.",
    "sources": {
      "brand": "src/client/src/styles.css",
      "surface": "src/client/src/app/config/primeng-theme.ts",
      "phase": "src/client/src/app/core/models/phase-colors.ts",
      "marker": "supabase/seed.sql",
      "rules": "docs/brand.md, docs/design-system.md"
    }
  },
  "color": {
    "brand": {
      "50": "#f0fdfa", "100": "#ccfbf1", "200": "#99f6e4", "300": "#5eead4",
      "400": "#2dd4bf", "500": "#14b8a6", "600": "#0d9488", "700": "#0f766e",
      "800": "#115e59", "900": "#134e4a", "950": "#042f2e"
    },
    "slate": {
      "50": "#f8fafc", "100": "#f1f5f9", "200": "#e2e8f0", "300": "#cbd5e1",
      "400": "#94a3b8", "500": "#64748b", "600": "#475569", "700": "#334155",
      "800": "#1e293b", "900": "#0f172a", "950": "#020617"
    },
    "green": {
      "50": "#f0fdf4", "100": "#dcfce7", "200": "#bbf7d0", "300": "#86efac",
      "400": "#4ade80", "500": "#22c55e", "600": "#16a34a", "700": "#15803d",
      "800": "#166534", "900": "#14532d"
    },
    "cyan": {
      "50": "#ecfeff", "100": "#cffafe", "200": "#a5f3fc", "300": "#67e8f9",
      "400": "#22d3ee", "500": "#06b6d4", "600": "#0891b2", "700": "#0e7490"
    },
    "blue": {
      "50": "#eff6ff", "100": "#dbeafe", "200": "#bfdbfe", "300": "#93c5fd",
      "400": "#60a5fa", "500": "#3b82f6", "600": "#2563eb", "700": "#1d4ed8"
    },
    "violet": {
      "50": "#f5f3ff", "100": "#ede9fe", "200": "#ddd6fe", "300": "#c4b5fd",
      "400": "#a78bfa", "500": "#8b5cf6", "600": "#7c3aed", "700": "#6d28d9"
    },
    "amber": {
      "50": "#fffbeb", "100": "#fef3c7", "200": "#fde68a", "300": "#fcd34d",
      "400": "#fbbf24", "500": "#f59e0b", "600": "#d97706", "700": "#b45309",
      "800": "#92400e", "900": "#78350f"
    },
    "orange": {
      "50": "#fff7ed", "100": "#ffedd5", "200": "#fed7aa", "300": "#fdba74",
      "400": "#fb923c", "500": "#f97316", "600": "#ea580c", "700": "#c2410c"
    },
    "red": {
      "50": "#fef2f2", "100": "#fee2e2", "200": "#fecaca", "300": "#fca5a5",
      "400": "#f87171", "500": "#ef4444", "600": "#dc2626", "700": "#b91c1c",
      "800": "#991b1b", "900": "#7f1d1d"
    }
  },
  "semantic": {
    "surface": {
      "page": "{color.slate.50}",
      "card": "#ffffff",
      "header": "{color.slate.50}"
    },
    "text": {
      "strong": "{color.slate.900}",
      "default": "{color.slate.700}",
      "muted": "{color.slate.500}",
      "placeholder": "{color.slate.400}",
      "onBrand": "#ffffff",
      "link": "{color.brand.700}"
    },
    "border": {
      "subtle": "{color.slate.100}",
      "default": "{color.slate.200}",
      "strong": "{color.slate.300}"
    },
    "accent": {
      "base": "{color.brand.600}",
      "hover": "{color.brand.700}",
      "active": "{color.brand.800}",
      "wash": "{color.brand.50}"
    },
    "phase": {
      "PRECLIN": "#cbd5e1", "P1": "#94a3b8", "P2": "#67e8f9",
      "P3": "#2dd4bf", "P4": "#a78bfa", "OBS": "#fbbf24", "fallback": "#64748b"
    },
    "developmentStatus": {
      "PRECLIN": "#cbd5e1", "P1": "#94a3b8", "P2": "#67e8f9", "P3": "#2dd4bf",
      "P4": "#a78bfa", "APPROVED": "#8b5cf6", "LAUNCHED": "#0d9488"
    },
    "marker": {
      "data": "#16a34a",
      "trial": "#475569",
      "trialLine": "#94a3b8",
      "regulatory": "#f97316",
      "approval": "#3b82f6",
      "launch": "#7c3aed",
      "loe": "#78350f",
      "genericEntry": "#d97706",
      "fallback": "#64748b"
    },
    "feedback": {
      "success": "{color.brand.700}",
      "error": "{color.red.800}",
      "warn": "{color.amber.800}",
      "info": "{color.slate.700}"
    }
  },
  "font": {
    "sans": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "mono": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Monaco, Consolas, monospace"
  },
  "fontSize": {
    "2xs": "10px", "xs": "11px", "sm": "12px", "base": "13px",
    "md": "14px", "lg": "16px", "xl": "20px"
  },
  "tracking": { "label": "0.14em", "wide": "0.08em", "normal": "0" },
  "radius": { "none": "0", "data": "0", "sm": "2px" },
  "space": {
    "1": "0.25rem", "2": "0.5rem", "3": "0.75rem",
    "4": "1rem", "5": "1.25rem", "6": "1.5rem"
  },
  "shadow": {
    "overlay": "0 10px 24px -12px rgba(15, 23, 42, 0.18)",
    "tooltip": "0 10px 24px -12px rgba(15, 23, 42, 0.28)"
  },
  "focus": { "ring": "0 0 0 2px rgba(13, 148, 136, 0.15)" }
}
