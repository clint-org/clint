{
  "name": "clinical-trial-dashboard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 8000",
    "build": "ng build",
    "test": "ng test",
    "test:unit": "playwright test --config=playwright.unit.config.ts",
    "test:e2e": "./e2e/run.sh",
    "test:e2e:ui": "./e2e/run.sh --ui",
    "test:e2e:fast": "./e2e/run.sh --reporter=list",
    "test:integration": "vitest run --config integration/vitest.config.ts",
    "test:units": "vitest run --config vitest.units.config.ts",
    "test:worker": "vitest run --config worker/vitest.config.mts",
    "lint": "ng lint && ./scripts/check-no-banana-ngmodel.sh && ./scripts/check-supabase-rls.sh",
    "docs:arch": "node scripts/gen-architecture.mjs"
  },
  "dependencies": {
    "@angular/animations": "^20.3.20",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.20",
    "@angular/compiler": "^20.3.20",
    "@angular/core": "^20.3.20",
    "@angular/forms": "^20.3.20",
    "@angular/platform-browser": "^20.3.20",
    "@angular/router": "^20.3.20",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@primeng/themes": "^20.4.0",
    "@supabase/supabase-js": "^2.49.0",
    "pptxgenjs": "^4.0.1",
    "primeng": "^20.4.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.25",
    "@angular/cli": "^20.3.25",
    "@angular/compiler-cli": "^20.3.20",
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260501.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.28.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
