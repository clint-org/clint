{
  "name": "clinical-trial-dashboard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 8000",
    "build": "ng build",
    "test": "ng test",
    "test:unit": "playwright test --config=playwright.unit.config.ts",
    "test:e2e": "./e2e/run.sh",
    "test:e2e:ui": "./e2e/run.sh --ui",
    "test:e2e:fast": "./e2e/run.sh --reporter=list",
    "test:integration": "vitest run --config integration/vitest.config.ts",
    "test:units": "vitest run --config vitest.units.config.ts",
    "test:worker": "vitest run --config worker/vitest.config.mts",
    "lint": "ng lint && ./scripts/check-no-banana-ngmodel.sh && ./scripts/check-supabase-rls.sh",
    "docs:arch": "node scripts/gen-architecture.mjs",
    "features:check": "node scripts/features-drift.mjs check",
    "features:stub": "node scripts/features-drift.mjs stub",
    "features:near": "node scripts/features-drift.mjs near",
    "features:surfaces-index": "node scripts/features-drift.mjs surfaces-index",
    "test:scripts": "node --test scripts/features/__tests__/*.test.mjs"
  },
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@primeng/themes": "^21.0.4",
    "@supabase/supabase-js": "^2.49.0",
    "@types/diff": "^7.0.2",
    "diff": "^9.0.0",
    "pptxgenjs": "^4.0.1",
    "primeng": "^21.1.6",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260501.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^9.28.0",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
