# Provider credentials for OpenTofu runs.
#
# RETIRED as the source of truth in WS4. Infisical now holds these -- project
# `clint`, environment `shared`, folder `/iac` -- and `infisical run --env=shared
# --path=/iac -- tofu <cmd>` injects them per run (see README). The local
# `.env.local` is no longer used; this file remains only as documentation of which
# variables tofu needs and as an emergency offline fallback if Infisical is
# unreachable (copy to `.env.local`, fill in, and `source` it before `tofu`).
#
# Variable notes:
# - TF_VAR_cloudflare_account_id feeds var.cloudflare_account_id (the TF_VAR_
#   prefix is required -- do not rename).
# - The CF token is the scoped Cloudflare API token (the tofu/IaC token, distinct
#   from the wrangler-deploy token).
# - The B2 key is a dedicated read+write management key scoped to clint-db-backups
#   (distinct from the write-only key the backup pipeline uses).

export CLOUDFLARE_API_TOKEN='REPLACE_WITH_TOKEN'
export TF_VAR_cloudflare_account_id='REPLACE_WITH_ACCOUNT_ID'
export B2_APPLICATION_KEY_ID='REPLACE_WITH_B2_KEY_ID'
export B2_APPLICATION_KEY='REPLACE_WITH_B2_APP_KEY'
