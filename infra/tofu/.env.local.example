# Local provider credentials for OpenTofu runs (WS3, CLI-driven local execution).
#
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# `.env.local` is sourced before each `tofu` command so the provider can read
# CLOUDFLARE_API_TOKEN, and TF_VAR_cloudflare_account_id feeds var.cloudflare_account_id.
#
# These are shell env vars at runtime, never committed. In WS4 they move to Infisical.
# The token is the scoped Cloudflare API token you minted in the dashboard.

export CLOUDFLARE_API_TOKEN='REPLACE_WITH_TOKEN'
export TF_VAR_cloudflare_account_id='REPLACE_WITH_ACCOUNT_ID'
